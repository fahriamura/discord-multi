{
  "name": "discord-multi",
  "version": "1.0.0",
  "description": "Lightweight multi-profile Discord client — no voice/video, minimal UI, multiple accounts",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:mac": "electron-builder --mac --x64",
    "build:all": "electron-builder --win --x64 --linux --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.fahriamura.discord-multi",
    "productName": "Discord Multi",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network",
      "icon": "assets/icon.png",
      "desktopName": "Discord Multi",
      "syncDesktopName": true
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.png",
      "category": "public.app-category.social-networking"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "discord",
    "multi-profile",
    "lightweight"
  ],
  "author": {
    "name": "fahriamura",
    "email": "fahriamura@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
